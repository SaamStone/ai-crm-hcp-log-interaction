# Groq API key - create one at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Model to use for the LangGraph agent
GROQ_MODEL=llama-3.3-70b-versatile

# Database URL. Defaults to local SQLite so the project runs with zero setup.
# Swap for Postgres or MySQL in production, e.g.:
#   postgresql+psycopg2://user:password@localhost:5432/hcp_crm
#   mysql+pymysql://user:password@localhost:3306/hcp_crm
DATABASE_URL=sqlite:///./hcp_crm.db

# Comma-separated list of origins allowed to call the API
CORS_ORIGINS=http://localhost:5173
